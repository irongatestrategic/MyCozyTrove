<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  
  <!-- CSS -->
  <link rel="stylesheet" href="/assets/css/main.css">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@700;900&display=swap" rel="stylesheet">
<meta name='impact-site-verification' value='0a9ea97a-332d-4c50-afbd-dc892e583c4b'>
</head>
<body>
  {% include "partials/header.njk" %}
  
  {% if isHome %}
  <section class="hero">
    <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>Gear That Works When It Matters</h1>
    <p class="hero-subtitle">Honest reviews from real fishing trips and backcountry weekends</p>
    <a href="#featured-reviews" class="btn-hero">Browse the Gear →</a>
    </div>
  </section>
  {% endif %}
  
  <main class="site-main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>
  
  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        
        <div class="footer-section">
          <h4>{{ site.name }}</h4>
          <p>{{ site.tagline }}</p>
          <p>Real testing. Honest limitations. Gear that works when it matters.</p>
        </div>
        
        <div class="footer-section">
          <h4>Reviews</h4>
          <ul>
            <li><a href="/reviews/power/">Power & Energy</a></li>
            <li><a href="/reviews/water/">Water & Filtration</a></li>
            <li><a href="/reviews/gear/">Gear & Equipment</a></li>
            <li><a href="/reviews/fishing/">Fishing</a></li>
            <li><a href="/reviews/self-sufficiency/">Self-Sufficiency</a></li>
			<li><a href="/reviews/camping/">Camping</a></li>
          </ul>
        </div>
        
        <div class="footer-section">
          <h4>Information</h4>
          <ul>
            <li><a href="/pages/about/">About</a></li>
            <li><a href="/pages/contact/">Contact</a></li>
            <li><a href="/pages/privacy-policy/">Privacy Policy</a></li>
            <li><a href="/pages/terms-of-service/">Terms of Service</a></li>
          </ul>
        </div>
        
        <div class="footer-section">
          <h4>Affiliate Disclosure</h4>
          <p>We earn commissions when you purchase through our links at no extra cost to you. We only recommend products we genuinely use and trust.</p>
        </div>
        
      </div>
      
      <div class="footer-bottom">
        <p>&copy; {{ site.year }} {{ site.business }}. All rights reserved.</p>
        <p>Contact: <a href="/cdn-cgi/l/email-protection#4f34346f3c263b2a612c20213b2e2c3b6f3232">{{ site.contact }}</a></p>
      </div>
      
    </div>
  </footer>
  
  <script data-cfasync=